---
import Base from "../../layouts/Base.astro";
import ClosingCTA from "../../components/ClosingCTA.astro";
import { doctors, business } from "../../data/site";

export function getStaticPaths() {
  return doctors.map((d) => ({ params: { doctor: d.slug }, props: { doctor: d } }));
}
const { doctor } = Astro.props;
const initials = doctor.name.replace("Dr. ", "").split(" ").map((w) => w[0]).slice(0, 2).join("");
const others = doctors.filter((d) => d.slug !== doctor.slug);
---
<Base
  title={`${doctor.name} - ${doctor.title} | Dermamedics Makati`}
  description={`${doctor.blurb}`}
  path={`/doctors/${doctor.slug}`}
>
  <section class="relative mesh-aubergine grain text-cream overflow-hidden">
    <div class="relative z-10 mx-auto max-w-7xl px-5 sm:px-8 pt-32 pb-16 sm:pt-40 sm:pb-20">
      <nav class="text-sm text-cream/60 mb-6" aria-label="Breadcrumb">
        <a href="/doctors" class="hover:text-champagne">Our doctors</a> <span class="text-champagne">›</span> <span class="text-cream/90">{doctor.name}</span>
      </nav>
      <div class="grid lg:grid-cols-12 gap-10 items-center">
        <div class="lg:col-span-4" data-reveal="left">
          <div class="aspect-[4/5] rounded-3xl flex items-center justify-center relative overflow-hidden glass-dark">
            <span class="font-display text-8xl font-bold text-champagne/90">{initials}</span>
            <span class="absolute bottom-4 right-4 text-[10px] text-cream/45">portrait to follow</span>
          </div>
        </div>
        <div class="lg:col-span-8">
          <p class="eyebrow text-champagne-soft" data-reveal>{doctor.title} · {doctor.branch}</p>
          <h1 class="mt-4 font-display font-bold leading-[1.04] text-[clamp(2.4rem,6vw,4.4rem)]" data-reveal>{doctor.name}</h1>
          <p class="mt-6 max-w-2xl text-lg text-cream/85 text-pretty" data-reveal>{doctor.blurb}</p>
          <div class="mt-7 flex flex-wrap gap-2" data-reveal>
            {doctor.specialisms.map((s) => (
              <span class="text-sm rounded-full bg-white/10 text-cream px-3.5 py-1.5">{s}</span>
            ))}
          </div>
          <div class="mt-8 flex flex-wrap gap-3" data-reveal>
            <a href={business.messenger} target="_blank" rel="noopener" class="btn btn-champagne">Book with {doctor.name.split(" ").slice(0, 2).join(" ")}</a>
            <a href={`tel:${business.phonePrimaryTel}`} class="btn btn-ghost-light">Call {business.phonePrimaryDisplay}</a>
          </div>
        </div>
      </div>
    </div>
    <div class="absolute -bottom-px left-0 right-0 h-16 bg-gradient-to-b from-transparent to-[var(--color-cream)]"></div>
  </section>

  <section class="py-16 sm:py-24 bg-[var(--color-cream)]">
    <div class="mx-auto max-w-3xl px-5 sm:px-8">
      <h2 class="font-display text-2xl font-bold text-[var(--color-aubergine)]" data-reveal>Credentials</h2>
      <p class="mt-4 text-[var(--color-ink-soft)] leading-relaxed text-pretty" data-reveal>{doctor.credentialNote}</p>
      <div class="mt-8 rounded-3xl bg-[var(--color-paper)] ring-line p-7" data-reveal>
        <p class="eyebrow text-[var(--color-champagne-deep)] text-[0.62rem]">Specialisms</p>
        <ul class="mt-4 grid sm:grid-cols-2 gap-x-6 gap-y-2.5 text-[var(--color-aubergine)]">
          {doctor.specialisms.map((s) => (
            <li class="flex gap-2.5"><span class="text-[var(--color-champagne-deep)]">✦</span> {s}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="pb-20 sm:pb-28 bg-[var(--color-cream)]">
    <div class="mx-auto max-w-7xl px-5 sm:px-8">
      <h2 class="font-display text-2xl font-bold text-[var(--color-aubergine)] mb-6" data-reveal>The rest of the team</h2>
      <div class="grid sm:grid-cols-2 gap-5" data-stagger>
        {others.map((d) => (
          <a href={`/doctors/${d.slug}`} class="group rounded-3xl bg-[var(--color-paper)] ring-line p-7 hover:shadow-[var(--shadow-lift)] transition-all flex items-center gap-5">
            <span class="shrink-0 w-16 h-16 rounded-2xl flex items-center justify-center font-display text-2xl font-bold text-champagne" style="background:linear-gradient(150deg,#5a3c50,#2a1925)">{d.name.replace("Dr. ", "").split(" ").map((w) => w[0]).slice(0,2).join("")}</span>
            <div>
              <h3 class="font-display text-xl font-bold text-[var(--color-aubergine)] group-hover:text-[var(--color-champagne-deep)] transition-colors">{d.name}</h3>
              <p class="text-sm text-[var(--color-ink-soft)]">{d.title} · {d.branch}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <ClosingCTA />
</Base>
