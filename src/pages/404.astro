---
import Base from "../layouts/Base.astro";
import { business } from "../data/site";
---
<Base title="Page not found - Dermamedics Makati" description="The page you're looking for has moved or no longer exists." path="/404">
  <section class="relative mesh-aubergine grain text-cream overflow-hidden min-h-[80vh] flex items-center">
    <div class="relative z-10 mx-auto max-w-3xl px-5 sm:px-8 py-32 text-center">
      <p class="font-display text-[clamp(5rem,18vw,12rem)] font-bold leading-none text-champagne-soft">404</p>
      <h1 class="mt-4 font-display text-3xl sm:text-4xl font-bold">This page slipped away.</h1>
      <p class="mt-4 text-cream/80 text-pretty">The link may be old or mistyped. Let's get you back to something useful.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a href="/" class="btn btn-champagne">Back to home</a>
        <a href="/treatments" class="btn btn-ghost-light">Browse treatments</a>
        <a href={business.messenger} target="_blank" rel="noopener" class="btn btn-ghost-light">Message us</a>
      </div>
    </div>
  </section>
</Base>
