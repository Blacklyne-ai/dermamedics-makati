---
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import ClosingCTA from "../components/ClosingCTA.astro";
import { branches, business } from "../data/site";
---
<Base
  title="Two Branches - DermaMedics, Centuria Medical Makati"
  description="Both DermaMedics branches sit inside Centuria Medical Makati: the 17F main branch (Dr. Tan, Dr. Tee) and the 9F facial & body center (Doc Jam). Addresses, contacts and maps."
  path="/branches"
>
  <PageHero
    eyebrow={`${business.building} · Century City`}
    title="One building,"
    titleAccent="two floors."
    image="/photos/clinic-interior.jpg"
    lead="Both DermaMedics clinics share the same premier medical address on Kalayaan Ave. - the 17th-floor flagship and the 9th-floor facial & body center. Here's how to reach each."
  />

  <section class="py-16 sm:py-24 bg-[var(--color-cream)]">
    <div class="mx-auto max-w-7xl px-5 sm:px-8 space-y-10" data-stagger>
      {branches.map((b) => (
        <div class="rounded-[2rem] ring-line bg-[var(--color-paper)] overflow-hidden grid lg:grid-cols-2">
          <div class="p-8 sm:p-10">
            <div class="flex items-center justify-between">
              <span class="eyebrow text-[var(--color-gold-deep)] text-[0.62rem]">{b.isMain ? "Main branch" : "Facial & body center"}</span>
              <span class="font-display text-3xl font-bold text-[var(--color-gold)]">{b.floor.replace("th Floor","F").replace("st Floor","F")}</span>
            </div>
            <h2 class="mt-3 font-display text-3xl font-bold text-[var(--color-magenta)]">{b.name}</h2>
            <p class="mt-2 text-[var(--color-ink-soft)]">{b.unit}</p>
            <p class="mt-4 text-[var(--color-ink-soft)] leading-relaxed text-pretty">{b.note}</p>

            <ul class="mt-6 space-y-2.5 text-sm text-[var(--color-ink-soft)]">
              <li class="flex gap-2.5"><span class="text-[var(--color-gold-deep)]">›</span> {b.addressLine}</li>
              <li class="flex gap-2.5"><span class="text-[var(--color-gold-deep)]">›</span> {b.cityLine}</li>
              <li class="flex gap-2.5"><span class="text-[var(--color-gold-deep)]">›</span> Doctors: {b.doctors.join(", ")}</li>
              <li class="flex gap-2.5"><span class="text-[var(--color-gold-deep)]">›</span> {business.hours}</li>
              <li class="flex gap-2.5"><span class="text-[var(--color-gold-deep)]">›</span> <a href={`tel:${b.phoneTel}`} class="link-underline font-semibold text-[var(--color-magenta)]">{b.phoneDisplay}</a></li>
              {b.phoneExtra && (
                <li class="flex gap-2.5"><span class="text-[var(--color-gold-deep)]">›</span> Also: {b.phoneExtra.join(" · ")}</li>
              )}
            </ul>

            <div class="mt-7 flex flex-wrap gap-3">
              <a href={business.messenger} target="_blank" rel="noopener" class="btn btn-primary text-sm">Message us</a>
              <a href={`tel:${b.phoneTel}`} class="btn btn-ghost text-sm">Call branch</a>
            </div>
          </div>
          <div class="min-h-[320px] lg:min-h-0">
            <iframe
              title={`Map - ${b.name}`}
              class="w-full h-full min-h-[320px]"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              src="https://www.google.com/maps?q=Centuria+Medical+Makati,+Kalayaan+Ave,+Makati&output=embed">
            </iframe>
          </div>
        </div>
      ))}
    </div>
  </section>

  <ClosingCTA heading="Not sure which floor you need?" sub="Message us and we'll point you to the right branch - and book your free consultation while we're at it." />
</Base>
