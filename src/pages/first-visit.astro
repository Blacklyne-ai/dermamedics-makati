---
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import ClosingCTA from "../components/ClosingCTA.astro";
import { business } from "../data/site";

const steps = [
  { n: "01", t: "Message or call to book", d: "The fastest way to reach us is Facebook Messenger - it's how most of our patients book. You can also call the main branch, or request a callback. Tell us what you'd like to work on; no detail is too small." },
  { n: "02", t: "Your free aesthetic-doctor consultation", d: "A proper assessment with a doctor - your skin, your goals, your history. No sales script. If a treatment isn't right for you, we'll say so." },
  { n: "03", t: "An honest plan, with the price", d: "You'll leave the consultation with a tailored plan and a written, transparent price. No obligation to book on the day, and no surprises later." },
  { n: "04", t: "Treatment, at your pace", d: "When you're ready, we begin - one visit or a planned course, whichever suits you. The doctor you met is the one who treats you." },
];
const bring = [
  "A list of any medications or supplements you take",
  "Notes on past treatments or reactions, if any",
  "Photos of results you like (or want to avoid)",
  "Your questions - especially about cost",
];
---
<Base
  title="Your First Visit - Dermamedics Makati"
  description="What to expect at your free aesthetic-doctor consultation at Dermamedics: an honest assessment, a tailored plan, and transparent pricing before anything begins."
  path="/first-visit"
>
  <PageHero
    eyebrow="Free consultation · No obligation"
    title="What to expect"
    titleAccent="on your first visit."
    lead="If you've never had aesthetic treatment before, the first step is the one that matters most - and at Dermamedics it's free, unhurried, and honest from the start."
  />

  <section class="py-16 sm:py-24 bg-[var(--color-cream)]">
    <div class="mx-auto max-w-5xl px-5 sm:px-8">
      <div class="space-y-4" data-stagger>
        {steps.map((s) => (
          <div class="grid sm:grid-cols-12 gap-4 sm:gap-8 items-start rounded-3xl bg-[var(--color-paper)] ring-line p-7 sm:p-8">
            <div class="sm:col-span-2 font-display text-4xl font-bold text-[var(--color-champagne)]">{s.n}</div>
            <div class="sm:col-span-10">
              <h2 class="font-display text-2xl font-bold text-[var(--color-aubergine)]">{s.t}</h2>
              <p class="mt-2 text-[var(--color-ink-soft)] leading-relaxed text-pretty">{s.d}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-12 grid lg:grid-cols-2 gap-6">
        <div class="rounded-3xl bg-[var(--color-paper)] ring-line p-7" data-reveal>
          <p class="eyebrow text-[var(--color-champagne-deep)] text-[0.62rem]">Helpful to bring</p>
          <ul class="mt-4 space-y-2.5 text-[var(--color-ink-soft)]">
            {bring.map((b) => (
              <li class="flex gap-3"><span class="text-[var(--color-champagne-deep)]">✓</span> {b}</li>
            ))}
          </ul>
        </div>
        <div class="rounded-3xl mesh-aubergine grain text-cream p-7 relative overflow-hidden" data-reveal="right">
          <div class="relative z-10">
            <p class="eyebrow text-champagne-soft text-[0.62rem]">Good to know</p>
            <ul class="mt-4 space-y-2.5 text-cream/85 text-sm">
              <li class="flex gap-2.5"><span class="text-champagne">›</span> Both branches open {business.hoursShort}, daily</li>
              <li class="flex gap-2.5"><span class="text-champagne">›</span> Walk-ins accommodated, but booking means no waiting</li>
              <li class="flex gap-2.5"><span class="text-champagne">›</span> Inside {business.building}, Century City</li>
              <li class="flex gap-2.5"><span class="text-champagne">›</span> Health information handled under RA 10173</li>
            </ul>
            <a href="/treatment-discovery-quiz" class="btn btn-champagne w-full mt-6 text-sm">Take the quiz before you come</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <ClosingCTA />
</Base>
