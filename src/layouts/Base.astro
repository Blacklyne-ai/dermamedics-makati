---
import "@fontsource-variable/bodoni-moda";
import "@fontsource-variable/inter";
import "../styles/global.css";

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FloatingCTA from "../components/FloatingCTA.astro";
import CookieBanner from "../components/CookieBanner.astro";
import { business, branches } from "../data/site";

interface Props {
  title: string;
  description: string;
  path?: string;
}
const { title, description, path = "" } = Astro.props;
const siteName = "Dermamedics Makati";
const fullTitle = title.includes("Dermamedics") ? title : `${title} | ${siteName}`;
const base = Astro.site ?? "https://dermamedics-makati.pages.dev";
const canonical = new URL(path, base).toString();

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalClinic",
  name: business.legalName,
  alternateName: "Dermamedics Skin Makati",
  url: base.toString(),
  telephone: business.phonePrimaryIntl,
  email: business.email,
  image: new URL("/og-image.svg", base).toString(),
  priceRange: "₱₱",
  slogan: business.tagline,
  foundingDate: "2010",
  medicalSpecialty: ["Dermatology", "PlasticSurgery"],
  areaServed: ["Makati", "Bonifacio Global City", "Metro Manila"],
  address: {
    "@type": "PostalAddress",
    streetAddress: "17F Units 1725-1726, Centuria Medical Makati, Kalayaan Ave. cor. Salamanca St.",
    addressLocality: "Makati City",
    addressRegion: "Metro Manila",
    postalCode: "1210",
    addressCountry: "PH",
  },
  openingHours: "Mo-Su 10:00-20:00",
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: business.googleRating,
    bestRating: "5",
    reviewCount: business.googleReviewCount,
  },
  department: branches.map((b) => ({
    "@type": "MedicalClinic",
    name: `Dermamedics - ${b.name}`,
    telephone: b.phoneTel,
    address: { "@type": "PostalAddress", streetAddress: b.addressLine, addressLocality: "Makati City", addressCountry: "PH" },
  })),
};
---
<!doctype html>
<html lang="en-PH">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>if(!location.search.includes('nofx'))document.documentElement.classList.add('js');</script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#3d2737" />
    <meta name="robots" content="index, follow" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="/og-image.svg" />
    <meta property="og:locale" content="en_PH" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <set:html value={`<script type="application/ld+json">${JSON.stringify(orgSchema)}</script>`} />
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:z-[80] focus:left-4 focus:top-4 focus:rounded-full focus:bg-[var(--color-aubergine)] focus:px-5 focus:py-3 focus:text-cream">Skip to content</a>

    <div id="scroll-progress"></div>

    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <FloatingCTA />
    <CookieBanner />

    <script>
      import "../scripts/motion.ts";
    </script>
  </body>
</html>
