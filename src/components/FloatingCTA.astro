---
import { business } from "../data/site";
---
<div id="floating-cta" class="fixed bottom-5 right-4 sm:right-6 z-[55] flex flex-col items-end gap-3 opacity-0 translate-y-4 pointer-events-none transition-all duration-400">
  <a href={business.messenger} target="_blank" rel="noopener"
     class="group inline-flex items-center gap-2.5 rounded-full bg-[var(--color-magenta)] text-cream pl-4 pr-5 py-3.5 shadow-[var(--shadow-float)] hover:bg-[var(--color-magenta-deep)] transition-colors"
     aria-label="Message DermaMedics on Messenger">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.4 2 2 6.2 2 11.7c0 3.1 1.4 5.9 3.7 7.7V23l3.4-1.9c.9.3 1.9.4 2.9.4 5.6 0 10-4.2 10-9.7S17.6 2 12 2zm1 13.1l-2.5-2.7-4.9 2.7L11 9.2l2.6 2.7 4.8-2.7L13 15.1z"/></svg>
    <span class="text-sm font-semibold">Messenger</span>
  </a>
  <a href={`tel:${business.phonePrimaryTel}`}
     class="inline-flex items-center gap-2.5 rounded-full bg-[var(--color-gold)] text-[#4a0329] pl-4 pr-5 py-3.5 shadow-[var(--shadow-gold)] hover:bg-[var(--color-gold-deep)] hover:text-white transition-colors"
     aria-label={`Call ${business.phonePrimaryDisplay}`}>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6.6 10.8a15 15 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.24 11 11 0 0 0 3.5.56 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 11 11 0 0 0 .56 3.5 1 1 0 0 1-.24 1z" fill="currentColor"/></svg>
    <span class="text-sm font-semibold">Call</span>
  </a>
</div>

<script is:inline>
  (function () {
    var el = document.getElementById("floating-cta");
    function t() {
      if (window.scrollY > 220) { el.classList.remove("opacity-0","translate-y-4","pointer-events-none"); }
      else { el.classList.add("opacity-0","translate-y-4","pointer-events-none"); }
    }
    window.addEventListener("scroll", t, { passive: true });
    t();
  })();
</script>
