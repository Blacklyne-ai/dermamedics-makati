---
import { divisions } from "../data/treatments";
import { business } from "../data/site";

interface Props {
  limit?: number;
  heading?: boolean;
}
const { limit = 0, heading = true } = Astro.props;

// Curated result slots - one representative treatment per division (and a few extra).
// Image slots are consent-ready placeholders: real, consented patient photos are a
// flagged client-supply item. Honest framing, never fabricated "results".
const picks = [
  { div: "body-slimming", t: "korean-mesolipo", dur: "Course of 4 sessions", img: "/photos/body-slimming.jpg" },
  { div: "aesthetic-medicine", t: "korean-fillers", dur: "Single session", img: "/photos/treatment-injectable.jpg" },
  { div: "anti-ageing", t: "hifu-face", dur: "Results at 12 weeks", img: "/photos/skincare-closeup.jpg" },
  { div: "skin-brightening", t: "carbon-peel", dur: "3 sessions", img: "/photos/treatment-facial.jpg" },
  { div: "acne", t: "anti-acne-package", dur: "8-week package", img: "/photos/texture-detail.jpg" },
  { div: "aesthetic-medicine", t: "jawtox", dur: "Reviewed at 4 weeks", img: "/photos/korean-beauty.jpg" },
  { div: "lasers", t: "pico-laser", dur: "Course of sessions", img: "/photos/treatment-laser.jpg" },
  { div: "tattoo-removal", t: "laser-tattoo-removal", dur: "Multi-session package", img: "/photos/tattoo-removal.jpg" },
  { div: "skin-brightening", t: "q-switch-laser", dur: "Course of sessions", img: "/photos/hero-portrait.jpg" },
  { div: "anti-ageing", t: "thermage-flx", dur: "Single session", img: "/photos/consultation.jpg" },
  { div: "body-slimming", t: "cryolipolysis", dur: "Results over 12 weeks", img: "/photos/clinic-interior.jpg" },
  { div: "iv-drips", t: "whitening-glutathione-drip", dur: "Weekly course", img: "/photos/iv-drip.jpg" },
];

const items = picks
  .map((p) => {
    const d = divisions.find((x) => x.slug === p.div)!;
    const t = d.treatments.find((x) => x.slug === p.t);
    if (!t) return null;
    return { divisionSlug: d.slug, divisionName: d.name, glyph: d.glyph, name: t.name, korean: !!t.korean, dur: p.dur, slug: t.slug, img: p.img };
  })
  .filter(Boolean) as { divisionSlug: string; divisionName: string; glyph: string; name: string; korean: boolean; dur: string; slug: string; img: string }[];

const shown = limit ? items.slice(0, limit) : items;
const filters = [{ slug: "all", name: "All results" }, ...divisions.map((d) => ({ slug: d.slug, name: d.name }))]
  .filter((f) => f.slug === "all" || items.some((i) => i.divisionSlug === f.slug));
---
<section class="py-20 sm:py-28 bg-[var(--color-cream)]">
  <div class="mx-auto max-w-7xl px-5 sm:px-8">
    {heading && (
      <div class="max-w-2xl mb-10">
        <p class="eyebrow text-[var(--color-gold-deep)]" data-reveal>Real results · Filterable</p>
        <h2 class="mt-4 font-display font-bold leading-[1.05] text-[clamp(2rem,4.5vw,3.4rem)] text-[var(--color-magenta)]" data-reveal>
          Before &amp; after, <span class="italic font-normal">honestly framed.</span>
        </h2>
        <p class="mt-5 text-[var(--color-ink-soft)] text-pretty" data-reveal>
          Individual results vary, and every photo we publish is shared with explicit patient consent. Filter by what you're considering.
        </p>
      </div>
    )}

    {limit === 0 && (
      <div class="flex flex-wrap gap-2 mb-8" id="ba-filters" data-reveal>
        {filters.map((f, i) => (
          <button
            data-filter={f.slug}
            class={`ba-filter text-sm font-medium rounded-full px-4 py-2 ring-1 transition-all ${i === 0 ? "ring-[var(--color-magenta)] bg-[var(--color-magenta)] text-cream" : "ring-[var(--color-line)] text-[var(--color-ink-soft)] hover:ring-[var(--color-gold)]"}`}>
            {f.name}
          </button>
        ))}
      </div>
    )}

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5" id="ba-grid" data-stagger>
      {shown.map((it) => (
        <a href={`/treatments/${it.divisionSlug}/${it.slug}`} class="ba-card group card-lux photo photo-zoom photo-scrim relative block rounded-3xl overflow-hidden gold-frame aspect-[4/5]" data-div={it.divisionSlug} data-tilt="3">
          <img src={it.img} alt={`${it.name} at DermaMedics`} class="absolute inset-0 z-0" loading="lazy" onerror="this.style.display='none'" />
          <div class="absolute inset-0 z-0 mesh-magenta-deep opacity-50 mix-blend-multiply"></div>
          <span class="absolute z-10 top-4 left-4 text-[10px] uppercase tracking-[0.18em] text-cream/70 bg-[var(--color-magenta-deepest)]/50 rounded-full px-2.5 py-1">with patient consent</span>
          <span class="absolute z-10 top-4 right-4 font-display text-2xl text-gold-soft">{it.glyph}</span>
          <div class="absolute z-10 inset-x-0 bottom-0 p-6">
            <span class="eyebrow text-gold-soft text-[0.58rem]">{it.divisionName}{it.korean ? " · Korean" : ""}</span>
            <h3 class="mt-1.5 font-display text-xl font-bold text-cream">{it.name}</h3>
            <p class="mt-0.5 text-sm text-cream/75">{it.dur}</p>
            <span class="mt-3 inline-flex items-center gap-1.5 text-sm font-semibold text-gold-soft">Book this treatment <span class="transition-transform group-hover:translate-x-1">→</span></span>
          </div>
        </a>
      ))}
    </div>

    {limit > 0 && (
      <div class="mt-10 text-center" data-reveal>
        <a href="/before-after-gallery" class="btn btn-ghost">See the full results gallery</a>
      </div>
    )}
    <p class="mt-8 text-xs text-[var(--color-ink-soft)] max-w-2xl">
      Note: image slots above are consent-ready placeholders. Real before/after photography will be added with each patient's written consent. To discuss realistic outcomes for your skin, <a href={business.messenger} target="_blank" rel="noopener" class="underline text-[var(--color-gold-deep)]">message us</a>.
    </p>
  </div>
</section>

{limit === 0 && (
  <script is:inline>
    (function () {
      var btns = document.querySelectorAll(".ba-filter");
      var cards = document.querySelectorAll(".ba-card");
      btns.forEach(function (b) {
        b.addEventListener("click", function () {
          var f = b.getAttribute("data-filter");
          btns.forEach(function (x) {
            x.className = "ba-filter text-sm font-medium rounded-full px-4 py-2 ring-1 transition-all ring-[var(--color-line)] text-[var(--color-ink-soft)] hover:ring-[var(--color-gold)]";
          });
          b.className = "ba-filter text-sm font-medium rounded-full px-4 py-2 ring-1 transition-all ring-[var(--color-magenta)] bg-[var(--color-magenta)] text-cream";
          cards.forEach(function (c) {
            var show = f === "all" || c.getAttribute("data-div") === f;
            c.style.display = show ? "" : "none";
          });
        });
      });
    })();
  </script>
)}
