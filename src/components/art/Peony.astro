  <g stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" opacity="0.9">
    <!-- inner bloom -->
    <path d="M100 78c-9 0-16 7-16 16 0 7 5 13 11 15-7 1-13 7-13 15 0 9 8 16 18 16s18-7 18-16c0-8-6-14-13-15 6-2 11-8 11-15 0-9-7-16-16-16z"/>
    <path d="M100 86c-5 3-8 8-8 14 0 7 4 13 8 16 4-3 8-9 8-16 0-6-3-11-8-14z"/>
    <!-- mid petals -->
    <path d="M84 94c-12-6-26-3-33 7 8 5 19 5 28 0"/>
    <path d="M116 94c12-6 26-3 33 7-8 5-19 5-28 0"/>
    <path d="M86 120c-10 8-14 22-9 33 9-4 15-13 16-23"/>
    <path d="M114 120c10 8 14 22 9 33-9-4-15-13-16-23"/>
    <path d="M100 70c8-10 22-14 33-9-4 9-13 15-23 16"/>
    <!-- outer petals -->
    <path d="M70 86c-16-3-32 4-39 18 13 4 28 0 37-9"/>
    <path d="M130 86c16-3 32 4 39 18-13 4-28 0-37-9"/>
    <path d="M78 140c-8 14-7 31 4 42 8-9 11-23 7-35"/>
    <path d="M122 140c8 14 7 31-4 42-8-9-11-23-7-35"/>
    <!-- stem + leaves -->
    <path d="M100 152v34"/>
    <path d="M100 168c-7-4-16-3-21 3 6 4 15 4 21-1"/>
    <path d="M100 176c7-4 16-3 21 3-6 4-15 4-21-1"/>
  </g>
</svg>
